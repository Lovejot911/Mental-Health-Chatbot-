import { NextResponse } from "next/server";
import { analyzeMentalHealth } from "@/lib/ai";
import { getRecommendations } from "@/lib/recommendations";
import { connectDB } from "@/lib/mongodb";
import Assessment from "@/models/Assessment";

export async function POST(req: Request) {
  try {
    await connectDB();

    const body = await req.json();
    const { text } = body;

    if (!text) {
      return NextResponse.json(
        {
          error: "Text is required",
        },
        {
          status: 400,
        }
      );
    }

    const result = await analyzeMentalHealth(text);

    const topPrediction = result[0][0];

    const recommendations = getRecommendations(topPrediction.label);

    const savedAssessment = await Assessment.create({
      text,
      prediction: topPrediction.label,
      confidence: topPrediction.score,
      recommendations: recommendations.suggestions,
    });

    return NextResponse.json({
      success: true,
      data: savedAssessment,
      recommendations,
    });
  } catch (error) {
    console.log(error);

    return NextResponse.json(
      {
        error: "Server Error",
      },
      {
        status: 500,
      }
    );
  }
}
